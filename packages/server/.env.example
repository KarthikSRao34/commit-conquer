# ─── commit&conquer API — Environment Configuration ──────────────────────────
#
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED IN PRODUCTION] must be set when NODE_ENV=production.
# Variables with defaults will use the default value if not set.
#

# ── Server ─────────────────────────────────────────────────────────────────────

PORT=4000
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# Admin secret for protected admin routes [REQUIRED IN PRODUCTION]
ADMIN_SECRET=admin_dev_secret

# ── Stripe (Payment Processing) ───────────────────────────────────────────────
# Get your keys from https://dashboard.stripe.com/apikeys

# Stripe secret key (starts with sk_) [REQUIRED IN PRODUCTION]
# STRIPE_KEY=sk_test_...

# Stripe webhook signing secret (starts with whsec_) [REQUIRED IN PRODUCTION]
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Database ───────────────────────────────────────────────────────────────────
# Connection URI for your database [REQUIRED IN PRODUCTION]
# Uses in-memory stores in development if not set.

# DB_URL=postgres://user:password@localhost:5432/commit_conquer
