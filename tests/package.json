{
  "name": "tests",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "echo \"Run individual app dev scripts from their directories\"",
    "start:server": "ts-node packages/server/index.ts",
    "test": "node ../node_modules/jest/bin/jest.js --runInBand",
    "test:unit": "node ../node_modules/jest/bin/jest.js --testPathPattern=tests/unit --runInBand",
    "test:integration": "node ../node_modules/jest/bin/jest.js --testPathPattern=tests/integration --runInBand",
    "test:coverage": "node ../node_modules/jest/bin/jest.js --coverage --runInBand",
    "test:watch": "node ../node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "typescript": "^5.4.5"
  }
}
